    "node-fetch": "^2.7.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.0.0",
    "@types/node-fetch": "^2.6.13",
    "dotenv": "^16.3.1",
    "localtunnel": "^2.0.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.0.0"
  }
